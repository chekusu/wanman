{
  "name": "@wanman/cli",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./sdk": {
      "types": "./src/sdk.ts",
      "default": "./dist/sdk.js"
    }
  },
  "bin": {
    "wanman": "./dist/index.js"
  },
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "standalone": "node build-standalone.mjs",
    "standalone:linux": "node build-standalone.mjs --linux",
    "standalone:all": "node build-standalone.mjs --all",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@wanman/core": "workspace:*",
    "@wanman/runtime": "workspace:*",
    "@wanman/host-sdk": "workspace:*",
    "chalk": "^5.6.2",
    "log-update": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
